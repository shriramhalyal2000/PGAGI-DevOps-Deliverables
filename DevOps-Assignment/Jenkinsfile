pipeline{
    scm checkout
    agent{
        docker {
            image: node:18-alpine
        }
    }
    stages{
        stage("Build frontend"){
            steps{
                dir("frontend"){
                    sh '''
                    docker build -t frontend:1.0.0 .
                    '''
                }
            }
        }
        stage("Backend Build"){
            steps{
                dir("backend"){
                    sh '''
                    docker build -t backend:1.0.0 .
                    '''
                }
            }
        }
        stage("push to repo"){
            steps{
                withCredentials([usernamePassword(
                    credentialsId: "docker-hub-creds",//use same in pipeline config
                    usernameVariable: "dockerUsr",//docker hub user name variable referenced in pipeline cred shriram2105
                    passwordVariable: "dockerPass" //dockerhub password varibale referenced in pipeline cred push pull delete creds
                )]){
                sh '''
                echo "$dockerPass" | docker login -u "$dockerUsr" --password-stdin
                docker tag frontend:1.0.0 "$dockerUsr/frontend:1.0.0"
                docker tag backend:1.0.0 "$dockerUsr/backend:1.0.0"

                docker push "$dockerUsr/frontend:1.0.0"
                docker push "$dockerUsr/backend:1.0.0" 
                '''
                }
            }
        }
        stage("deploy"){
            steps{ //can be used to login any other machine to deploy artifacts by ssh  and its creds
                sh '''
                docker compose up -d 
                docker ps 
                '''
            }
        }
    }
}